# ─────────────────────────────────────────────────────────────────────────────
# SportsHub — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Flask-Mail ────────────────────────────────────────────────────────────────
MAIL_SERVER=
MAIL_PORT=
MAIL_USE_TLS=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Optional Business Config ──────────────────────────────────────────────────
GST_RATE=18
FREE_DELIVERY_ABOVE=999
DELIVERY_CHARGE=49
